# ── MongoDB ──────────────────────────────────────────
# Connection string for MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>

# ── Gemini AI (for story text generation) ────────────
# Uses gemini-flash-lite-latest model
GOOGLE_API_KEY=your_google_api_key_here

# ── fal.ai (for image generation) ────────────────────
# Uses flux/schnell model
FAL_KEY=your_fal_key_here

# ── Server ───────────────────────────────────────────
VUE_APP_PORT=8000

# ── Usage Limits ─────────────────────────────────────
FAL_DAILY_LIMIT=100
FAL_MONTHLY_LIMIT=500
