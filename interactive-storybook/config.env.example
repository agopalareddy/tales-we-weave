# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<app-name>

# OpenAI (for story text generation)
VUE_APP_OPENAI_API_KEY=sk-...

# fal.ai (for image generation - replaces DALL-E)
FAL_KEY=your_fal_key_here

# Server
VUE_APP_PORT=8000

# Usage limits
FAL_DAILY_LIMIT=50
FAL_MONTHLY_LIMIT=500
